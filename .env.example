# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# Optional client-side alias (Vite exposes VITE_* vars)
VITE_GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Google Maps — use either variable name (both are supported)
VITE_GOOGLE_MAPS_PLATFORM_KEY=""
VITE_GOOGLE_MAPS_API_KEY=""

# VITE_TICKETMASTER_API_KEY: Optional. Fetches real events from Ticketmaster Discovery API.
# Get a free key from: https://developer.ticketmaster.com/products-and-docs/apis/getting-started/
# Mapped event ids use prefix "tm_" (see src/lib/runtimeMode.ts); Home pages load via useHomeExternalEvents.
VITE_TICKETMASTER_API_KEY=""

# Optional API base + analytics (CoFounderBay-style production shell)
VITE_API_BASE_URL=""
VITE_ENABLE_ANALYTICS="false"
VITE_AI_USE_PROXY="true"
VITE_WS_URL=""

# Optional Firebase realtime (future — today Socket.IO via server.ts)
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_API_KEY=""
